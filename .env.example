SOMNEO_IP=192.168.123.123 # local IP of Somneo
USB_LIGHT=false

GCAL_CALENDAR_ID=<id>        # or a specific calendar ID
# Auth: set one, never both
GCAL_SERVICE_ACCOUNT_FILE=   # path to service account JSON (preferred, no token expiry)
GCAL_CREDENTIALS_FILE=credentials.json  # OAuth2 client secrets (used if SERVICE_ACCOUNT not set)
GCAL_TOKEN_FILE=token.json

KAKU_ADDRESS=12345678              # 26-bit address for lamp plugs (max 67108863)
KAKU_COFFEE_ADDRESS=87654321       # separate address for coffee machine (excluded from group commands)
KAKU_UNITS=0,1                     # comma-separated unit IDs to control in routines
KAKU_USE_GROUP=false               # if true, send a single group command instead of per-unit
KAKU_COFFEE_UNIT=2                 # plug unit ID for the coffee machine
KAKU_SENDOOK_PATH=/usr/local/bin/rpitx/sendook
KAKU_PULSE_US=275                  # pulse width in microseconds
KAKU_REPEATS=4                     # frame repetitions per send
KAKU_PAIR_DURATION=15              # seconds to keep sending during pairing window
KAKU_COFFEE_SENDS=3                # number of ON sends for coffee (spread over time for reliability)
KAKU_COFFEE_SEND_GAP=3.0           # seconds between coffee sends

DISCORD_BOT_ENABLED=false
DISCORD_BOT_TOKEN=<token>
DISCORD_OWNER_ID=<discord_user_id>
DISCORD_MEMBER_ID=                  # optional second user
SLEEP_TARGET_HOUR=23                # target sleep hour (24h local time)
SLEEP_DURATION_H=8                  # desired sleep duration in hours
DISCORD_NUDGE_ADVANCE_MIN=20        # minutes before event to send nudge DM
