SOMNEO_IP=192.168.123.123 # local IP of Somneo
USB_LIGHT=false

GCAL_CALENDAR_ID=<id>        # or a specific calendar ID
GCAL_CREDENTIALS_FILE=credentials.json
GCAL_TOKEN_FILE=token.json

KAKU_ADDRESS=12345678              # 26-bit address shared across all plugs (max 67108863)
KAKU_UNITS=0,1                     # comma-separated unit IDs to control in routines
KAKU_USE_GROUP=false               # if true, send a single group command instead of per-unit
KAKU_SENDOOK_PATH=/usr/local/bin/rpitx/sendook
KAKU_PULSE_US=275                  # pulse width in microseconds
KAKU_REPEATS=4                     # frame repetitions per send
KAKU_PAIR_DURATION=15              # seconds to keep sending during pairing window
