        "update": {
          "code": "const brightness = context.panel.elements.find(e => e.id === 'brightness')?.value || 0;\nconst ctype = parseInt(context.panel.elements.find(e => e.id === 'ctype')?.value || '2');\nfetch('http://turnip.lan:8091/api/light', {\n  method: 'POST',\n  headers: { 'Content-Type': 'application/json' },\n  body: JSON.stringify({ brightness: brightness, ctype: ctype })\n});\ncontext.grafana.notifySuccess(['Done', 'Light set to brightness ' + brightness]);",
          "confirm": false,
          "contentType": "application/json",
          "getPayload": "const payload = {};\ncontext.panel.elements.forEach((element) => {\n  if (!element.value) { return; }\n  payload[element.id] = element.value;\n});\nreturn payload;",
